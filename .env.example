FIREBASE_PROJECT_ID=aturduitku
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@aturduitku.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=https://www.aturduitku.com

ALLOWED_ORIGIN=https://www.aturduitku.com
ADMIN_EMAILS=creator@example.com

CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_AI_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast

TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ADMIN_CHAT_ID=your-private-admin-chat-id
TELEGRAM_WEBHOOK_SECRET=use-a-long-random-secret

# Production only. Use at least 32 random characters; never commit the real value.
# Vercel automatically sends it as Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=generate-a-unique-32-character-secret
